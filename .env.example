# Root copy of the CareGuide AI environment template.
# The Next.js app uses apps/web/.env.local.
# Copy apps/web/.env.example to apps/web/.env.local and fill values locally.
# Never put real secrets in this example file.

GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-2
GEMINI_EMBEDDING_DIMENSION=768
OPENFDA_API_KEY=your_openfda_api_key
NHS_WEBSITE_CONTENT_API_KEY=your_nhs_website_content_api_key

NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
DATABASE_URL=your_supabase_postgres_connection_string

DAILYMED_BASE_URL=https://dailymed.nlm.nih.gov/dailymed/services/v2
OPENFDA_BASE_URL=https://api.fda.gov
RXNAV_BASE_URL=https://rxnav.nlm.nih.gov/REST
MEDLINEPLUS_CONNECT_BASE_URL=https://connect.medlineplus.gov/service
NHS_WEBSITE_CONTENT_BASE_URL=https://api.nhs.uk
